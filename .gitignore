cat > .gitignore <<'EOF'
# Python cache
__pycache__/
*.pyc

# IDE / local config
.vscode/
.ultralytics/

# datasets
dataset/
dataset_preload/

# training / inference outputs
runs/
outputs/
test_examples/

# model weights / exported models
*.pt
*.pth
*.onnx
*.engine

# videos / compressed files
*.mp4
*.avi
*.mov
*.zip
*.rar

# env files
.env
EOF